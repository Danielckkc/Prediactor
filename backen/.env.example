# Backend (FastAPI) configuration — copy to `.env` and fill in as needed.
# The user/password/db/port below MUST match the root .env POSTGRES_* values.
DATABASE_URL=postgresql+asyncpg://prediactor:prediactor@localhost:5432/prediactor
CORS_ORIGINS=http://localhost:3000
# AI provider: "mock" uses the built-in stub (no key needed).
# Switch to "anthropic" and set ANTHROPIC_API_KEY to use a real model later.
AI_PROVIDER=mock

# --- RedNote scraper (scraper/rednote) ---
# Your logged-in xiaohongshu.com cookie (must contain a1= and web_session=).
# Get it: log in -> DevTools (F12) -> Network -> click any xiaohongshu request
# -> Request Headers -> copy the full "cookie:" value.
RED_COOKIE=""
# Optional: email alert when the cookie expires (Gmail needs an App Password).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASSWORD="your-app-password"
# NOTIFY_EMAIL="you@gmail.com"
